rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getPlanUpper(planId) {
      return planId == null ? 'FREE' : planId.upper();
    }

    function isSubscriptionActive(bizId) {
      let biz = get(/databases/$(database)/documents/businesses/$(bizId)).data;
      return biz.subscription_status == 'active';
    }

    function hasPremiumAccess(bizId) {
      let biz = get(/databases/$(database)/documents/businesses/$(bizId)).data;
      return biz.subscription_status == 'active' && 
             (getPlanUpper(biz.plan_id) == 'PREMIUM');
    }

    // Helper para verificar se o ID é válido (previne IDs gigantes ou caracteres estranhos)
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isGlobalAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email == 'italocar19@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helper para verificar se o usuário é dono do negócio
    function checkProfLimit(bizId) {
      let biz = get(/databases/$(database)/documents/businesses/$(bizId)).data;
      let plan = biz.plan_id == null ? 'FREE' : biz.plan_id;
      let limitAmount = (plan == 'PREMIUM' || plan == 'premium') ? 999 :
                  (plan == 'BUSINESS' || plan == 'business') ? 999 :
                  (plan == 'PRO' || plan == 'pro') ? 5 : 1;
      let used = biz.usage_professionals == null ? 0 : biz.usage_professionals;
      return used < limitAmount;
    }

    function checkServiceLimit(bizId) {
      let biz = get(/databases/$(database)/documents/businesses/$(bizId)).data;
      let plan = biz.plan_id == null ? 'FREE' : biz.plan_id;
      let limitAmount = (plan == 'FREE' || plan == 'free') ? 3 : 999;
      let used = biz.usage_services == null ? 0 : biz.usage_services;
      return used < limitAmount;
    }

    function isBizOwner(bizId) {
      return isSignedIn() && bizId != null && bizId != "" && 
             exists(/databases/$(database)/documents/businesses/$(bizId)) && 
             get(/databases/$(database)/documents/businesses/$(bizId)).data.owner_id == request.auth.uid;
    }

    // Entity Validations
    function isValidService(data) {
      return data.business_id is string && isValidId(data.business_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.duration is number && data.duration > 0 &&
             (data.description == null || (data.description is string && data.description.size() <= 500));
    }


    function isValidClient(data) {
      return data.business_id is string && isValidId(data.business_id) &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             (data.phone == null || (data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20));
    }

    function isValidAppointment(data) {
      return data.business_id is string && isValidId(data.business_id) &&
             data.service_id is string && isValidId(data.service_id) &&
             data.professional_id is string && isValidId(data.professional_id) &&
             data.client_id is string && isValidId(data.client_id) &&
             data.appointment_date is string && data.appointment_date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.start_time is string && data.start_time.matches('^\\d{2}:\\d{2}:\\d{2}$') &&
             data.status is string && data.status in ['pending', 'confirmed', 'cancelled', 'completed', 'in_progress', 'pending_payment'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isGlobalAdmin() || request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isGlobalAdmin();
      allow delete: if isGlobalAdmin();
    }

    // Businesses: Configuração central do Micro SaaS
    match /businesses/{bizId} {
      allow read: if true; // Público para landing pages
      allow create: if isSignedIn() && 
                      incoming().keys().hasAll(['owner_id', 'name']) &&
                      request.auth.uid == incoming().owner_id &&
                      isValidId(bizId);
      allow update: if isGlobalAdmin() || 
                      (isSignedIn() && request.auth.uid == existing().owner_id);
      allow delete: if isGlobalAdmin() || (isSignedIn() && request.auth.uid == existing().owner_id);
    }

    // Profiles: Configurações do usuário (Dono do Negócio)
    match /profiles/{userId} {
      allow read: if isGlobalAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Coleções gerenciadas pelo dono (Professionals, Services, Units, Working Hours)
    match /professionals/{id} {
      allow read: if true; 
      allow create: if isSignedIn() && isBizOwner(request.resource.data.business_id);
      allow update: if isSignedIn() && isBizOwner(resource.data.business_id);
      allow delete: if isSignedIn() && isBizOwner(resource.data.business_id);
    }

    match /services/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isBizOwner(request.resource.data.business_id);
      allow update: if isSignedIn() && isBizOwner(resource.data.business_id);
      allow delete: if isSignedIn() && isBizOwner(resource.data.business_id);
    }

    match /units/{id} {
      allow read: if true;
      allow create: if isBizOwner(incoming().business_id) && isValidId(id);
      allow update: if isBizOwner(existing().business_id);
      allow delete: if isBizOwner(existing().business_id);
    }

    match /working_hours/{id} {
      allow read: if true;
      allow create: if isBizOwner(incoming().business_id) && isValidId(id);
      allow update: if isBizOwner(existing().business_id);
      allow delete: if isBizOwner(existing().business_id);
    }

    // Appointments: Onde o cliente agenda
    match /appointments/{id} {
      // Cliente acessa individualmente ou via listagem segura
      allow get: if true; 
      allow list: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      
      allow create: if false; // Only backend admin SDK can create
      allow update: if isGlobalAdmin() || (isSignedIn() && isBizOwner(existing().business_id));
      allow delete: if isGlobalAdmin() || (isSignedIn() && isBizOwner(existing().business_id));
    }

    match /daily_schedules/{id} {
      allow read: if true;
      allow write: if false; // Only backend API books here securely.
    }

    // Clients: CRM
    match /clients/{clientId} {
      allow get: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      allow list: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      
      allow create: if false; // Only backend admin SDK can create
      allow update: if isGlobalAdmin() || (isSignedIn() && isBizOwner(existing().business_id));
      allow delete: if isGlobalAdmin() || (isSignedIn() && isBizOwner(existing().business_id));
    }

    match /loyalty_rewards/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }
    
    match /loyalty_redemptions/{id} {
      allow read: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      allow write: if false; // Only backend admin SDK can modify redemptions
    }

    match /system_events/{id} {
      allow read: if isGlobalAdmin();
      allow write: if false; // Only backend admin SDK can access
    }

    match /feedbacks/{feedbackId} {
      allow read: if isGlobalAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isGlobalAdmin();
    }

    match /admin_audit_logs/{id} {
      allow read, write: if isGlobalAdmin();
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow create: if isValidId(notifId); 
      allow update: if isBizOwner(existing().business_id);
      allow delete: if isBizOwner(existing().business_id);
    }

    match /notification_queue/{id} {
      allow read, write: if false; // Only backend admin SDK can access
    }

    match /loyalty_missions/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    match /loyalty_mission_progress/{id} {
      allow read: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      allow write: if false; // Only backend admin SDK can modify mission progress
    }

    match /loyalty_points/{id} {
      allow read: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      allow write: if false; // Only backend admin SDK can modify loyalty points
    }

    match /loyalty_balances/{id} {
      allow read: if true;
      allow create, update, delete: if false; // Must be modified by backend
    }

    match /loyalty_levels/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    match /style_gallery/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    match /loyalty_configs/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }
    
    match /subscriptions/{id} {
      allow read: if isGlobalAdmin() || (isSignedIn() && isBizOwner(resource.data.business_id));
      allow write: if false; // Only backend admin SDK can modify subscriptions
    }

    match /campaign_results/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    match /instagram_posts/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    match /processing_queue/{jobId} {
      allow read, write: if false; // Only backend admin SDK can access
    }

    match /learning_insights/{insightId} {
      allow get: if isGlobalAdmin() || isBizOwner(resource.data.businessId);
      allow list: if isGlobalAdmin();
      allow list: if isBizOwner(resource.data.businessId);
      allow create, update: if isGlobalAdmin();
      allow delete: if isGlobalAdmin();
    }

    match /marketing_configs/{configId} {
      allow read: if isBizOwner(resource.data.businessId);
      allow create, update: if isBizOwner(request.resource.data.businessId);
      allow delete: if isBizOwner(resource.data.businessId);
    }

    match /marketing_campaigns/{campaignId} {
      allow read: if isBizOwner(resource.data.businessId);
      allow create, update: if isBizOwner(request.resource.data.businessId) || isGlobalAdmin();
      allow delete: if isBizOwner(resource.data.businessId);
    }

    match /fixed_client_slots/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }

    // Avaliações
    match /reviews/{id} {
      allow read: if true;
      allow write: if false; // Only backend admin SDK can write reviews
    }

    // Descontos e Ofertas
    match /discounts/{id} {
      allow read: if isSignedIn();
      allow write: if isGlobalAdmin();
    }

    match /user_offers/{id} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /analytics_events/{id} {
      allow create: if false; // Only backend admin SDK can create
      allow read, update, delete: if false;
    }

    match /playbook_logs/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }
    
    match /smart_campaigns/{id} {
      allow read: if true;
      allow create: if isBizOwner(request.resource.data.business_id);
      allow update: if isBizOwner(resource.data.business_id);
      allow delete: if isBizOwner(resource.data.business_id);
    }
    
    match /business_automations/{bizId} {
      allow read: if isBizOwner(bizId);
      allow write: if isBizOwner(bizId);
    }
    
    match /business_integrations/{bizId} {
      allow read: if true; // allow public pages to read pixel ids
      allow write: if isBizOwner(bizId) && getPlanUpper(get(/databases/$(database)/documents/businesses/$(bizId)).data.plan_id) in ["PRO", "BUSINESS", "PREMIUM"];
    }

    match /platform_settings/{docId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }
  }
}
